<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0;</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
    <Title>Transaction-Aware Domain Architecture Toolkit</Title>
    <Version>2.0.2</Version>
    <Authors>Uta Sugane</Authors>
    <Description>A library of interfaces and classes useful for implementing Transaction-Aware Domain Architecture (TADA).</Description>
    <SignAssembly>False</SignAssembly>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/Uta-member/CSStack.TADA</RepositoryUrl>
    <PackageTags>TADA;DDD;CSStack;</PackageTags>
    <PackageReleaseNotes>ITransactionManagerの公開メソッドを増やした</PackageReleaseNotes>
    <PackageLicenseExpression> MIT</PackageLicenseExpression>
    <PackageIcon>CSStack.png</PackageIcon>
  </PropertyGroup>

  <ItemGroup>
	  <None Include="CSStack.png">
		  <Pack>True</Pack>
		  <PackagePath>\</PackagePath>
	  </None>
	  <None Include="..\..\README.md">
		  <Pack>True</Pack>
		  <PackagePath>\</PackagePath>
	  </None>
  </ItemGroup>

</Project>
